{
  "name": "realestate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "demo:prepare": "node e2e/ensure-demo-data.mjs && node e2e/unique-listing-covers.mjs",
    "demo:record": "npm run demo:prepare && playwright test e2e/demo-video.spec.ts",
    "demo:convert": "node scripts/ensure-demo-music.mjs && node scripts/convert-demo-video.mjs",
    "demo:check": "node scripts/check-demo-video.mjs",
    "demo:video": "npm run demo:record && npm run demo:convert && npm run demo:check"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "ffmpeg-static": "^5.3.0",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
